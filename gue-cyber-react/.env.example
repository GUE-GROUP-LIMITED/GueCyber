VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: email alerts for new job applications via EmailJS
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_APPLICATION_ALERT_TO_EMAIL=

# Optional: override Supabase Edge Function name for candidate acknowledgment email
VITE_SUPABASE_ACK_FUNCTION_NAME=send-application-ack
# Optional: override Supabase Edge Function name for newsletter acknowledgment email
VITE_SUPABASE_NEWSLETTER_ACK_FUNCTION_NAME=send-newsletter-ack

# Supabase Edge Function secrets (set with `supabase secrets set`, not in Vercel)
# EMAILJS_SERVICE_ID=
# EMAILJS_ACK_TEMPLATE_ID=
# EMAILJS_NEWSLETTER_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=
# ACK_COMPANY_NAME=Gue Cyber
